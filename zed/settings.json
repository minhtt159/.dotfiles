{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "icon_theme": "Zed (Default)",
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "soft_wrap": "editor_width",
  "base_keymap": "VSCode",
  "theme": {
    "mode": "dark",
    "light": "Ayu Dark",
    "dark": "Ayu Dark"
  },
  "ui_font_size": 15,
  "buffer_font_size": 14.0,
  "buffer_font_family": "Hack Nerd Font",
  "git_status": true,
  "tab_size": 2,
  "copilot": {
    "disabled_globs": [".env*"]
  },
  "enable_language_server": true,
  "remove_trailing_whitespace_on_save": true,
  "lsp": {
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    }
  }
}
